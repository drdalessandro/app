# Servidor FHIR R4 de BioWellness (Medplum, datos en Argentina). Para desarrollo local usar http://localhost:8103/
MEDPLUM_BASE_URL=https://api.medplum.com.ar/
MEDPLUM_CLIENT_ID= # Optional
# Los siguientes valores son específicos de la instancia/proyecto de BioWellness:
# completar con el Project ID y las claves Google/Recaptcha de api.medplum.com.ar.
GOOGLE_CLIENT_ID= # Optional
RECAPTCHA_SITE_KEY= # Optional
MEDPLUM_PROJECT_ID= # Project ID del proyecto BioWellness en api.medplum.com.ar
